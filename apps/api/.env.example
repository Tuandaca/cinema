# ====================================
# 🎬 Cinema API - Environment Variables
# ====================================
# Copy file này thành .env và điền thông tin thực tế vào.

# --- Database (Supabase PostgreSQL) ---
# Xem hướng dẫn lấy URL: docs/16-supabase-guide.md
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# --- JWT Authentication ---
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=3001

# --- Redis / Upstash (Phase 4: Seat Locking) ---
# Đăng ký tại: https://upstash.com (Free-tier)
UPSTASH_REDIS_URL="redis://default:xxxxx@global-xxxxx.upstash.io:6379"

# --- OpenAI (Phase 6: AI Assistant) ---
# Đăng ký tại: https://platform.openai.com
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxx"

# --- Cloudinary (Phase 3: Image Storage) ---
# Đăng ký tại: https://cloudinary.com (Free-tier)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
