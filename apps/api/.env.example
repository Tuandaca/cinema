# ====================================
# 🎬 Cinema API - Environment Variables
# ====================================
# Copy file này thành .env và điền thông tin thực tế vào.

# --- Database (Supabase PostgreSQL) ---
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# --- JWT Authentication ---
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# --- Server ---
PORT=3001
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# --- Redis / Upstash (Phase 4: Seat Locking) ---
UPSTASH_REDIS_URL="redis://default:xxxxx@global-xxxxx.upstash.io:6379"

# --- AI Assistant (Phase 6: Gemini Flash 2.5) ---
GOOGLE_GENERATIVE_AI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- Movie Data Providers ---
TRAKT_CLIENT_ID="your-trakt-client-id"
OMDB_API_KEY="your-omdb-api-key"

# --- Cloudinary (Phase 3: Image Storage) ---
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
