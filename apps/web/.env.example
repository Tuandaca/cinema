# ====================================
# 🎬 Cinema Web - Environment Variables
# ====================================
# Copy file này thành .env.local và điền thông tin thực tế vào.

# --- Backend API URL ---
NEXT_PUBLIC_API_URL="http://localhost:3001"

# --- Supabase Client (Phase 3+: Frontend Auth / Realtime) ---
# Lấy từ Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJxxxxxxxxxxxxxxxxxxxxxxxxx"
